# URL of the backend API server (no trailing slash).
# In production, set this to your Railway backend service URL.
# In development, leave it unset — the Vite dev server will proxy /api to localhost:3000.
# VITE_API_URL=https://api.yourdomain.com

# URL of the public website — used for the "Back to Website" link on the login screen.
# VITE_WEBSITE_URL=https://yourdomain.com